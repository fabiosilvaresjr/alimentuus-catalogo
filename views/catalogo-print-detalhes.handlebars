<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Catálogo Alimentuus 2026</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Helvetica Neue', Arial, sans-serif;
            background-color: white;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .header-catalogo {
            background-color: #006837; 
            color: white;
            padding: 40px 20px; 
            text-align: center;
            margin-bottom: 40px;
            border-bottom: 6px solid #8CC63F; 
        }

        .produto-card {
            border: 1px solid #ddd;
            padding: 20px;
            margin-bottom: 30px;
            page-break-inside: avoid; 
            text-align: center;
            background: #fff;
            height: 520px; 
            overflow: hidden; 
            display: flex;
            flex-direction: column;
        }

        .produto-img {
            height: 180px;
            width: 100%;
            object-fit: contain;
            margin-bottom: 20px;
            flex-shrink: 0; 
        }

        .produto-titulo {
            color: #006837;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 1.2rem;
            margin-bottom: 10px;
            height: 60px; 
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .produto-peso {
            font-size: 1.1rem;
            color: #000;
            font-weight: bold;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid #8CC63F;
        }

        .texto-descricao {
            color: #333;
            font-size: 0.95rem;
            line-height: 1.4;
            height: 140px; /* Trava a altura (Ajuste esse valor testando com o texto do Mineral UP) */
            overflow: hidden; /* Corta o que passar desse tamanho, sem quebrar o layout do card */
            display: -webkit-box; /* Truque extra para colocar "..." no final do texto se ele for muito grande */
            -webkit-line-clamp: 7; /* Número de linhas que vão aparecer */
            -webkit-box-orient: vertical;
        }

        @media print {
            .navbar, header, .btn, .d-print-none, nav {
                display: none !important;
            }

            body, html {
                margin: 0;
                padding: 0;
            }

            @page { margin: 1.5cm; }

            .produto-detalhe-container {
            page-break-after: always;
            }
        }

    </style>
</head>

<body>

    <div class="header-catalogo d-flex justify-content-center align-items-center gap-5 position-relative">
        
        <img src="/uploads/logo-boi.png" alt="Logo" style="height: 140px;">
        
        <div class="text-start">
            <h1 class="mb-0 fw-bold display-4" style="line-height: 1;">ALIMENTUUS</h1>
            <h3 class="fw-light mb-0">Nutrição Animal</h3>
            <p class="mt-3 mb-0 opacity-75 fs-5">Catálogo de Produtos 2026</p>
        </div>

        <div class="d-print-none position-absolute end-0 top-50 translate-middle-y me-4" style="width: 200px;">
            <button onclick="window.print()" class="btn btn-success shadow-lg btn-lg d-block w-100 mb-2">
                🖨️ Imprimir PDF
            </button>
            <button onclick="window.close()" class="btn btn-secondary shadow-lg btn-lg d-block w-100">
                Fechar
            </button>
        </div>

    </div>

    <div class="container text-center mb-5" id="areaFachada" style="page-break-inside: avoid;">
        <img src="/uploads/fachada.jpg" 
             onerror="this.style.display='none'; document.getElementById('areaFachada').style.display='none';" 
             style="width: 100%; max-height: 300px; object-fit: cover; border-radius: 10px; border: 3px solid #006837; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">
    </div>

<div class="container">
        {{#each produtos}}
        <div class="produto-detalhe-container" style="page-break-after: always; page-break-inside: avoid; padding-top: 50px; padding-bottom: 50px;"> 
            
            <div class="row align-items-center"> 
                <div class="col-5 text-center">
                    <img src="/uploads/{{this.imagem}}" class="img-fluid rounded shadow-sm border" style="max-height: 400px; object-fit: contain;">
                </div>
          
                <div class="col-7 text-start">
                    <span class="badge bg-success mb-2 fs-6">{{this.categoria}}</span>
                    <h1 class="display-4 fw-bold text-success" style="line-height: 1.1;">{{this.nome}}</h1>
                    <p class="text-muted fs-5 mb-4">Embalagem: {{this.quantidade}}</p>
                    
                    <hr>
                    
                    <p class="lead mt-3" style="text-align: justify; font-size: 1.1rem;">{{this.descricao_curta}}</p>
       
                    <hr>

                    {{#if this.imagem_garantia}}
                    <h5 class="text-success mt-4">Níveis de Garantia</h5>
                    <div class="text-center p-2 border rounded bg-light">
                        <img src="/uploads/{{this.imagem_garantia}}" class="img-fluid rounded" style="max-height: 350px; object-fit: contain;">
                    </div>
                    {{/if}}
                    
                </div>
            </div>
            
        </div>
        {{/each}}
    </div>

</body>
</html>