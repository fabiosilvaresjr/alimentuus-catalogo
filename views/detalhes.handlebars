<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Ficha Técnica - {{produto.nome}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body { font-family: Arial, sans-serif; background-color: white; }
        
        /* 2. PADRONIZAÇÃO DO CABEÇALHO VERDE DO CLIENTE */
        .header-print {
            background-color: #006837; 
            color: white;
            padding: 30px; 
            border-bottom: 6px solid #8CC63F; 
            display: flex;
            align-items: center;
            gap: 40px;
            margin-bottom: 30px;
        }

        /* 3. CONTROLE DE IMPRESSÃO (A4 e Cores) */
        @media print {
            .d-print-none { display: none !important; }
            body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            @page { margin: 1cm; size: A4; }
        }
    </style>
</head>
<body>

    <div class="header-print">
        <img src="/uploads/logo-boi.png" alt="Logo" style="height: 100px;">
        <div class="text-start">
            <h1 class="mb-0 fw-bold" style="font-size: 2.4rem;">ALIMENTUUS</h1>
            <h4 class="fw-light mb-0">Nutrição Animal</h4>
            <p class="mt-2 mb-0 opacity-75">Ficha Técnica do Produto</p>
            
            <p class="mt-2 mb-0" style="font-size: 11px; color: #b3d4b6;">
                © 2026 Alimentuus | Desenvolvido por <strong>Fabio Almeida</strong> (<a href="https://www.linkedin.com/in/fabio-silvaresjunior/" target="_blank" style="color: #b3d4b6; text-decoration: underline;">Contato</a>)
            </p>
        </div>

        <div class="ms-auto d-print-none">
            <button onclick="window.print()" class="btn btn-success shadow-sm">🖨️ Imprimir PDF</button>
            <a href="/" class="btn btn-outline-light ms-2">Voltar</a>
        </div>
    </div>

    <div class="container">
        <div class="row align-items-center">
            <div class="col-5 text-center">
                <img src="/uploads/{{produto.imagem}}" class="img-fluid rounded border shadow-sm" style="max-height: 450px; object-fit: contain;">
            </div>

            <div class="col-7">
                <span class="badge bg-success mb-2 fs-6">{{produto.categoria}}</span>
                <h1 class="display-5 fw-bold text-success">{{produto.nome}}</h1>
                <p class="text-muted fs-5">Embalagem: {{produto.quantidade}}</p>
                
                <hr>
                
                <p class="lead" style="text-align: justify; font-size: 1.1rem;">
                    {{produto.descricao_curta}}
                </p>

                <hr>

                {{#if produto.imagem_garantia}}
                <h5 class="text-success mt-4">Níveis de Garantia</h5>
                <div class="p-2 border rounded bg-light text-center">
                    <img src="/uploads/{{produto.imagem_garantia}}" class="img-fluid rounded" style="max-height: 250px;">
                </div>
                {{/if}}
            </div>
        </div>
    </div>

</body>
</html>