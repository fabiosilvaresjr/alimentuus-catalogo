<style>
    @media print {
        body { background-color: white !important; }
        .d-print-none { display: none !important; } 
        .shadow-sm { box-shadow: none !important; } 
    }
</style>

<div class="container mt-5">
    <div class="d-flex justify-content-between mb-3 d-print-none">
        <a href="/" class="btn btn-outline-secondary">← Voltar para o Catálogo</a>
        <button onclick="window.print()" class="btn btn-success shadow-lg">🖨️ Gerar PDF / Imprimir</button>
    </div>

    <div class="row">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div style="height: 400px; background-color: #e9ecef; display: flex; align-items: center; justify-content: center;">
                    <img src="/uploads/{{produto.imagem}}" class="img-fluid rounded shadow-sm border" alt="{{produto.nome}}" style="max-height: 400px;">
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <span class="badge bg-success mb-2">{{produto.categoria}}</span>
            <h1 class="display-5 fw-bold text-success">{{produto.nome}}</h1>
            
            <p class="text-muted">Embalagem: {{produto.quantidade}}</p>

            <hr>

            <p class="lead mt-3">{{produto.descricao_curta}}</p>

            <hr>

            {{#if produto.imagem_garantia}}
            <h5 class="text-success mt-4">Níveis de Garantia</h5>
            <div class="p-3 bg-light rounded border">
                <img src="/uploads/{{produto.imagem_garantia}}" class="img-fluid rounded shadow-sm border" alt="Garantia">
            </div>
            {{/if}}

        </div>
    </div>
</div>