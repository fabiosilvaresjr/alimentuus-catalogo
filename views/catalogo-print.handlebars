<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Catálogo Alimentuus 2026</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
        body {
            font-family: 'Helvetica Neue', Arial, sans-serif;
            background-color: white;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .header-catalogo {
            background-color: #006837;
            color: white;
            padding: 40px 20px; 
            text-align: center;
            margin-bottom: 30px;
            border-bottom: 6px solid #8CC63F;
        }

        .grid-produtos {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 40px; 
        }

        .produto-card {
            border: 1px solid #ddd;
            padding: 20px;
            page-break-inside: avoid !important;
            break-inside: avoid !important;
            text-align: center;
            background: #fff;
            display: flex;
            flex-direction: column;
        }

        .produto-img {
            height: 200px;
            width: 100%;
            object-fit: contain;
            margin-bottom: 20px;
            flex-shrink: 0; 
        }

        .produto-titulo {
            color: #006837;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 1.2rem;
            margin-bottom: 10px;
            min-height: 60px;
            height: auto; 
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .produto-peso {
            font-size: 1.1rem;
            color: #000;
            font-weight: bold;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid #8CC63F;
        }

        .texto-descricao {
            color: #333;
            font-size: 0.95rem;
            line-height: 1.4;
            text-align: justify;
            height: auto; 
            margin-top: 10px;
        } 

        @media print {
            .navbar, header, .btn, .d-print-none, nav {
                display: none !important;
            }
            body, html {
                margin: 0;
                padding: 0;
            }
            @page { 
                margin: 1cm; 
            }
        }
    </style>

</head>

<body>

    <div class="header-catalogo d-flex justify-content-center align-items-center gap-5 position-relative">
        
        <img src="/uploads/logo-boi.png" alt="Logo" style="height: 140px;">
        
        <div class="text-start">
            <h1 class="mb-0 fw-bold display-4" style="line-height: 1;">ALIMENTUUS</h1>
            <h3 class="fw-light mb-0">Nutrição Animal</h3>
            <p class="mt-3 mb-0 opacity-75 fs-5">Catálogo de Produtos 2026</p>
        </div>

        <div class="d-print-none position-absolute end-0 top-50 translate-middle-y me-4" style="width: 200px;">
            <button onclick="window.print()" class="btn btn-success shadow-lg btn-lg d-block w-100 mb-2">
                🖨️ Imprimir PDF
            </button>
            <button onclick="window.close()" class="btn btn-secondary shadow-lg btn-lg d-block w-100">
                Fechar
            </button>
        </div>

    </div>

    <div class="container text-center mb-5" id="areaFachada" style="page-break-inside: avoid;">
        <img src="/uploads/fachada.jpg" 
             onerror="this.style.display='none'; document.getElementById('areaFachada').style.display='none';" 
             style="width: 100%; max-height: 300px; object-fit: cover; border-radius: 10px; border: 3px solid #006837; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">
    </div>

    <div class="container mb-5">
        <div class="grid-produtos">
            {{#each produtos}}
            <div class="produto-card shadow-sm">
                <img src="/uploads/{{this.imagem}}" class="produto-img">
                
                <div class="produto-titulo">
                    <span>{{this.nome}}</span>
                </div>
                <div class="produto-peso">{{this.quantidade}}</div>
              
                <div class="texto-descricao">
                    {{this.descricao_curta}}
                </div>
            </div>
            {{/each}}
        </div>
    </div>

</body>
</html>
