<div class="card shadow">
    <div class="card-header bg-warning text-dark">
        <h4 class="mb-0">✏️ Editar Produto</h4>
    </div>
    <div class="card-body">
        <form action="/produtos/atualizar" method="POST" enctype="multipart/form-data">
            
            <input type="hidden" name="id" value="{{produto.id}}">

            <div class="mb-3 bg-light p-3 rounded border">
                <label class="form-label fw-bold">📸 Alterar Foto (Opcional)</label>
                
                <div class="mb-2">
                    <span class="text-muted small">Atual:</span>
                    <img src="/uploads/{{produto.imagem}}" height="50" class="rounded border ms-2">
                </div>

                <input type="file" name="imagem" class="form-control" accept="image/*">
                <div class="form-text">Deixe em branco para manter a foto atual.</div>
            </div>

            <div class="mb-3">
                <label>Nome do Produto:</label>
                <input type="text" name="nome" class="form-control" value="{{produto.nome}}" required>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label>Categoria:</label>
                    <input type="text" name="categoria" class="form-control" value="{{produto.categoria}}" required>
                </div>
                <div class="col-md-4 mb-3">
                    <label>Peso/Embalagem:</label>
                    <input type="text" name="quantidade" class="form-control" value="{{produto.quantidade}}" required>
                </div>
                <div class="col-md-4 mb-3">
                    <label>Preço (R$):</label>
                    <input type="number" step="0.01" name="preco" class="form-control" value="{{produto.preco}}" required>
                </div>
            </div>

            <div class="mb-3 bg-light p-3 rounded border">
                <label class="form-label fw-bold text-success">📢 Descrição Curta (Marketing)</label>
                
                <textarea class="form-control" name="descricao_curta" rows="3" maxlength="350" required>{{produto.descricao_curta}}</textarea>
                
                <div class="form-text text-danger">Limite máximo de 350 caracteres para manter o catálogo alinhado.</div>
            </div>

            <div class="mb-3 bg-light p-3 rounded border border-success">
                <label class="form-label fw-bold text-success">📊 Alterar Tabela de Garantia</label>
                
                {{#if produto.imagem_garantia}}
                <div class="mb-2">
                    <small class="text-muted">Atual:</small><br>
                    <img src="/uploads/{{produto.imagem_garantia}}" style="max-height: 80px;" class="border rounded shadow-sm">
                </div>
                {{/if}}

                <input type="file" name="imagem_garantia" class="form-control" accept="image/*">
                <div class="form-text">Deixe em branco para manter a tabela de garantia atual.</div>
            </div>

            <button type="submit" class="btn btn-success w-100">💾 Salvar Alterações</button>
            <a href="/" class="btn btn-outline-secondary w-100 mt-2">Cancelar</a>
        </form>
    </div>
</div>